[Unit]
Description=Barg.tj Gunicorn
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/barg.tj/Back-End
EnvironmentFile=/var/www/barg.tj/Back-End/.env
ExecStart=/var/www/barg.tj/Back-End/.venv/bin/gunicorn     --workers 3 --bind 0.0.0.0:8001     --access-logfile /var/log/barg-gunicorn.log     --error-logfile /var/log/barg-gunicorn.err     config.wsgi:application
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
