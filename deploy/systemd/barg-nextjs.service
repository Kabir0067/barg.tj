[Unit]
Description=Barg.tj Next.js
After=network.target

[Service]
User=www-data
Group=www-data
WorkingDirectory=/var/www/barg.tj/Front-End
Environment=NODE_ENV=production
Environment=PORT=3001
ExecStart=/usr/bin/node /var/www/barg.tj/Front-End/node_modules/next/dist/bin/next start --port 3001
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
