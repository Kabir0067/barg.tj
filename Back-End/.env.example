# ==========================================================
#  Barg.tj  —  Back-End production environment variables
#  Copy real values into your server's environment
#  (systemd EnvironmentFile, Docker, or hosting dashboard).
# ==========================================================

# Security — GENERATE A NEW SECRET KEY before going live:
#   python -c "from django.core.management.utils import get_random_secret_key as g; print(g())"
DJANGO_SECRET_KEY=replace-with-a-long-random-secret

# Turn OFF debug in production
DJANGO_DEBUG=False

# Domains that may serve the API (comma separated)
DJANGO_ALLOWED_HOSTS=barg.tj,www.barg.tj,api.barg.tj

# Front-End origins allowed to call the API
CORS_ALLOWED_ORIGINS=https://barg.tj,https://www.barg.tj
CSRF_TRUSTED_ORIGINS=https://barg.tj,https://www.barg.tj

# Force HTTPS (set False only if TLS is terminated elsewhere without proxy header)
SECURE_SSL_REDIRECT=True

# Telegram order notifications
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# AI assistant providers (fallback order: Gemini -> Groq -> OpenRouter)
GEMINI_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key
OPENROUTER_API_KEY=your-openrouter-key
